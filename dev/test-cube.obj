# Test cube with 6 materials (one per face)
# For testing sprite sheet mapping with faceIds

# 8 vertices of a unit cube centered at origin
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5

# 6 faces, each with a different material
usemtl front
f 1 2 3 4

usemtl back
f 6 5 8 7

usemtl top
f 4 3 7 8

usemtl bottom
f 5 6 2 1

usemtl right
f 2 6 7 3

usemtl left
f 5 1 4 8
